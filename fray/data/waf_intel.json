    "cloudflare": {
      "display_name": "Cloudflare",
      "detection_mode": "hybrid",
      "block_behavior": {
        "status_codes": [400, 403, 503],
        "block_patterns": ["400 empty body (edge HTTP parser)", "403 with cf-ray + block page", "503 challenge page"],
        "challenge_types": ["js_challenge", "turnstile_captcha", "managed_challenge"],
        "timing_signature": "blocked responses 30-50ms faster than normal (edge short-circuit)"
      },
      "bypass_techniques": {
        "effective": [
          {
            "technique": "double_encoding",
            "payload_example": "%253Cscript%253E",
            "description": "Double URL encoding bypasses signature matching on decoded values",
            "confidence": "medium",
            "tested_date": "2026-03-06",
            "tested_on": ["shopify.com (Cloudflare)"]
          },
          {
            "technique": "unicode_normalization",
            "payload_example": "%ef%bc%9cscript%ef%bc%9e (fullwidth chars)",
            "description": "Fullwidth Unicode equivalents of < and > bypass ASCII signature rules",
            "confidence": "low",
            "tested_date": "2026-03-06",
            "notes": "Blocked by Cloudflare on shopify.com but NOT by GitHub/Stripe"
          },
          {
            "technique": "http1_via_biso",
            "payload_example": "URL-encoded XSS via HTTP/1.1 raw socket",
            "description": "Cloudflare Browser Isolation (BISO) proxy may not apply WAF rules on HTTP/1.1 requests",
            "confidence": "high",
            "tested_date": "2026-03-06",
            "tested_on": ["dalisec.io"],
            "notes": "HTTP/2 (curl) gets 403, HTTP/1.1 (raw socket) gets 200. BISO-specific bypass."
          },
          {
            "technique": "content_type_confusion",
            "payload_example": "POST with Content-Type: text/plain containing XSS",
            "description": "Some Cloudflare rules only inspect application/x-www-form-urlencoded and application/json",
            "confidence": "medium"
          },
          {
            "technique": "chunked_transfer",
            "payload_example": "Transfer-Encoding: chunked with split payload across chunks",
            "description": "Splitting payload across HTTP chunks can evade single-pass signature matching",
            "confidence": "medium"
          },
          {
            "technique": "case_variation",
            "payload_example": "<ScRiPt>alert(1)</ScRiPt>",
            "description": "Mixed case can bypass case-sensitive signature rules",
            "confidence": "low",
            "notes": "Cloudflare normalizes case in most managed rules now"
          }
        ],
        "ineffective": [
          {
            "technique": "null_byte_injection",
            "payload_example": "%00<script>",
            "description": "Cloudflare strips null bytes before rule evaluation",
            "tested_date": "2026-03-06"
          },
          {
            "technique": "raw_unencoded_chars",
            "payload_example": "<script>alert(1)</script> in URL",
            "description": "Edge HTTP parser returns 400 before WAF evaluation",
            "tested_date": "2026-03-06"
          }
        ]
      },
      "detection_gaps": {
        "signature": {
          "blocks": ["XSS (encoded)", "SQLi (encoded)", "Command Injection (encoded)", "Log4Shell", "Path Traversal"],
          "misses": [],
          "notes": "Comprehensive signature coverage on managed ruleset"
        },
        "anomaly": {
          "blocks": ["double_encoding"],
          "misses": ["long_parameter (2000 chars)", "null_bytes", "unicode_abuse"],
          "notes": "Anomaly detection is selective — double encoding triggers but other anomalies pass"
        }
      },
      "rate_limiting": {
        "default_threshold": null,
        "headers_exposed": false,
        "notes": "No X-RateLimit-* headers by default. Rate limiting is configured per-zone via dashboard rules."
      },
      "recommended_categories": ["modern_bypasses", "csp_bypass", "prototype_pollution", "ssti"],
